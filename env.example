# model-set Environment Variables
# Copy this file to .env and fill in your values

# =====================================================
# GLOBAL MCP SERVERS (always available)
# =====================================================

# Stitch - UI design generation (uses Google Cloud auth)
# Requires: gcloud auth login && gcloud auth application-default set-quota-project YOUR_PROJECT_ID
GOOGLE_CLOUD_PROJECT=selbtatsystems
STITCH_API_KEY=
GEMINI_API_KEY=

# Context7 - Documentation lookup
CONTEXT7_API_KEY=

# =====================================================
# LOCAL MCP SERVERS (project-specific, set in project .env)
# =====================================================

# PostgreSQL database connection
# POSTGRES_DATABASE_URI=postgresql://user:password@host:5432/database

# Redis connection
# REDIS_URL=redis://:password@localhost:6379/0

# Stripe (if using)
# STRIPE_API_KEY=sk_test_your-stripe-key-here
